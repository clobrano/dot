# reorder priorities
uda.priority.values = H,M,,L
urgency.uda.priority.L.coefficient=0
urgency.uda.priority.M.coefficient=2
urgency.uda.priority.H.coefficient=3

# UDA url
uda.url.type=string
uda.url.label=URL

# UDA dur, for calendar events duration
uda.dur.type=string
uda.dur.label=DUR

# use ancestral urgency if higher than own
urgency.inherit=on

# taskwarrior customization
report.next.columns=id,tags,description.count,due.countdown
report.next.labels=ID,Tag,Desc,Due
report.next.filter=status:pending -WAITING ( due:today or scheduled:today or +doing)

# Weekly scheduled tasks
report.weekly_goals.description=This week (Due & Completed)
report.weekly_goals.columns=description.count,due,end
report.weekly_goals.filter=status.not:deleted status.not:recurring ((due.after:sow and due.before:eow) or (end.after:sow and end.before:eow) or (scheduled.after:sow and scheduled.before:eow))
report.weekly_goals.sort=project
report.weekly_goals.column.width=5000

# Quarter Goals
report.quarter.description=Quarter goals
report.quarter.columns=description.count,due.relative,end
report.quarter.filter=status.not:deleted +quartergoal
report.quarter.sort=project
report.quarter.column.width=5000
