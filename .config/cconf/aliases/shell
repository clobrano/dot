# YAZI
alias y=yazi

#######################################################################################
# CAT/BAT
if [[ $(which batcat 2>/dev/null | grep bin | wc -l) = "1" ]]; then
    alias cat="batcat --style=plain"
else if [[ $(which bat 2>/dev/null | grep bin | wc -l) = "1" ]]; then
        alias cat="bat --style=plain"
    fi
fi

#######################################################################################
# LS/EZA
if command -v eza 2>&1 >/dev/null; then
    alias ls=eza
fi

