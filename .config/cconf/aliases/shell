#######################################################################################
# Date helpers
alias now='date +"%F-%H%M%S"'
alias today='date +"%F"'
alias yesterday='date --date="yesterday" +"%F"'
alias lastweek='date --date="last week" +"%F"'
alias friday='date --date="Friday" +"%F"'
alias eow='date --date="next Sunday" +"%F"'
alias sow='date --date="last Monday" +"%F"'

