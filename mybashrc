# ~/.bashrc: executed by bash(1) for non-login shells.

# If not running interactively, don't do anything
case $- in
    *i*) ;;
      *) return;;
esac

# Shell behavior
stty -ixon          # Disable terminal freeze (C-s)
shopt -s autocd
shopt -s checkwinsize

# History
shopt -s histappend
HISTCONTROL=ignoreboth
HISTSIZE=1000
HISTFILESIZE=2000
export HISTTIMEFORMAT="%d/%m/%y %T "

# Terminal
COLORTERM=gnome-terminal
TERM=xterm-256color
color_prompt=yes

# Chroot prompt label
if [ -z "${debian_chroot:-}" ] && [ -r /etc/debian_chroot ]; then
    debian_chroot=$(cat /etc/debian_chroot)
fi

[[ -e /etc/profile.d/vte-2.91.sh ]] && source /etc/profile.d/vte-2.91.sh

# Bash completion
if ! shopt -oq posix; then
    if [ -f /usr/share/bash-completion/bash_completion ]; then
        . /usr/share/bash-completion/bash_completion
    elif [ -f /etc/bash_completion ]; then
        . /etc/bash_completion
    fi
fi

export EDITOR="nvim"
export GIT_TERMINAL_PROMPT=1
export ME=$HOME/Me
export GCC_COLORS=1
export CDPATH=$HOME/workspace
export GOPATH=$HOME/workspace/golang
export GOBIN=${GOPATH}/bin

# Redtimer
export REDTIMER_LOG_SESSION_PATH="${HOME}/MyBox/work/telit/redtimer-session-log.txt"
export REDTIMER_WORK_SESSION_TIME=40
export REDTIMER_PAUSE_SESSION_TIME=5

# PATH
PATH=$PATH:$HOME/workspace/script-fu
PATH=$PATH:$HOME/toolkit
PATH=$PATH:${GOBIN}
PATH=~/.local/bin:$PATH
PATH=$PATH:/usr/local/go/bin
PATH=$PATH:/opt/nvim-linux-x86_64/bin
[[ -d "$HOME/.atuin" ]] && PATH=$PATH:$HOME/.atuin/bin
[[ -d "$HOME/.cargo" ]] && PATH=$HOME/.cargo/bin:$PATH
export PATH

# Aliases (itsmine and ls overrides live in .config/cconf/aliases/shell)
alias bi='source ${HOME}/.bashrc'
alias ls='ls --color=auto --group-directories-first'
alias ll='ls -l'
alias la='ls -alF'
alias grep='grep --color=auto'

# Dotfiles (sources all files under .config/cconf/aliases/)
source "$HOME/.config/cconf/dot/dotfiles.sh"

# Fuzzy finder
if command -v fzf &>/dev/null; then
    source <(fzf --bash)
    export FZF_DEFAULT_COMMAND='ag --hidden --ignore .git -g "" -U'
fi

# Task completions
if command -v task &>/dev/null; then
    complete -F _task wk me next wknext
fi

# bash-preexec must be sourced before tools that hook into it (atuin, zoxide)
[[ -f ~/.bash-preexec.sh ]] && source ~/.bash-preexec.sh

# zoxide (replaces cd)
if command -v zoxide &>/dev/null; then
    eval "$(zoxide init bash --cmd cd)"
fi

# atuin (shell history)
if command -v atuin &>/dev/null; then
    eval "$(atuin init bash --disable-up-arrow)"
fi

# Override any zsh-style _nvim completion that causes "setopt: command not found"
# errors when bash resolves completions for the nvim alias
complete -o default n 2>/dev/null

# Local overrides
[[ -f "$HOME/.local_bashrc" ]] && source "$HOME/.local_bashrc"
[[ -f "$HOME/Documents/unsharable" ]] && source "$HOME/Documents/unsharable"
